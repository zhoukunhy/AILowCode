{
  "name": "@ai-lowcode/code-generator",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist node_modules",
    "test": "jest"
  },
  "dependencies": {
    "@ai-lowcode/shared-types": "workspace:*",
    "@ai-lowcode/lang-ai-core": "workspace:*",
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/node": "^20.11.0"
  }
}
