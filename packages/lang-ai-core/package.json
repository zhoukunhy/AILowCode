{
  "name": "@ai-lowcode/lang-ai-core",
  "version": "1.0.0",
  "description": "AI Language Model Core - LangChain integration with LLM factory, RAG, and Chroma vector store",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "node build.js",
    "dev": "tsup src/index.ts --format cjs --watch",
    "clean": "rm -rf dist node_modules",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
  "dependencies": {
    "@langchain/community": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "@langchain/openai": "^0.3.0",
    "chromadb": "^1.8.0",
    "express": "^4.18.0",
    "langchain": "^0.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0"
  },
  "peerDependencies": {
    "@ai-lowcode/shared-types": "workspace:*"
  },
  "keywords": [
    "langchain",
    "langgraph",
    "chroma",
    "rag",
    "llm",
    "ai",
    "deepseek",
    "qwen",
    "openai"
  ],
  "author": "AI Lowcode Team",
  "license": "MIT"
}
