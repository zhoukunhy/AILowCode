# ===================================
# 应用配置
# ===================================
NODE_ENV=development
PORT=3000

# ===================================
# 数据库配置
# ===================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ai_lowcode

# ===================================
# Redis 配置
# ===================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===================================
# JWT 配置
# ===================================
JWT_SECRET=ai-lowcode-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ===================================
# CORS 配置
# ===================================
CORS_ORIGIN=*

# ===================================
# AI 配置（可选）
# ===================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
